# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (must match docker/.env) ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=auction_db
DB_USER=auction_user
DB_PASSWORD=yourpassword

# ─── JWT / RS256 Keys ─────────────────────────────────────────────────────────
# Paste the contents of keys/private.pem (generated via: node scripts/generateKeys.js)
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# Paste the contents of keys/public.pem
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_EXPIRES_IN=1h
